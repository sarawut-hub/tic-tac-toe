<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title || 'Tic-Tac-Toe Neo' }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet">
    @vite(['resources/css/app.css', 'resources/js/app.js'])
    <style>
        .p-1 { padding: 1rem; }
        .m-0 { margin: 0; }
        .gap-1 { gap: 1rem; }
    </style>
    @if(slots.head)
      {{{ await slots.head() }}}
    @endif
</head>
<body>
    <nav class="glass-nav flex-between p-1">
        <div class="text-gradient f-large">
            TIC-TAC-TOE NEO
        </div>
        <div>
            @if(auth.isAuthenticated)
                <div class="flex-center gap-1">
                    <span class="f-medium">{{ auth.user.username }}</span>
                    <form action="/auth/logout" method="POST" class="m-0">
                        {{ csrfField() }}
                        <button type="submit" class="mui-btn mui-btn--secondary mui-btn--small m-0">Logout</button>
                    </form>
                </div>
            @else
                <a href="/" class="mui-btn mui-btn--primary mui-btn--small m-0">Login</a>
            @end
        </div>
    </nav>

    <main>
        {{{ await slots.main() }}}
    </main>
</body>
</html>
